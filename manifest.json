{
  "manifest_version": 3,
  "name": "Couple Start Page",
  "short_name": "StartPage",
  "version": "2.0.0",
  "description": "A calm, elegant new tab experience — personalized for couples.",

  "chrome_url_overrides": {
    "newtab": "index.html"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://cdn.jsdelivr.net/*",
    "https://api.bmkg.go.id/*",
    "https://date.nager.at/*",
    "https://logam-mulia-api.iamutaki.workers.dev/*",
    "https://query1.finance.yahoo.com/*",
    "https://corsproxy.io/*",
    "https://suggestqueries.google.com/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*"
  ],

  "icons": {
    "16":  "assets/icons/github.svg",
    "48":  "assets/icons/github.svg",
    "128": "assets/icons/github.svg"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
